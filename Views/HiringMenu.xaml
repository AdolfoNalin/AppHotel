<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppHotel.Views.HiringMenu"
             Title="Menu"
             NavigationPage.HasNavigationBar="False">
    <VerticalStackLayout
        VerticalOptions="CenterAndExpand"
        Padding="10"
        >
        <Label 
            Text="Cálculo da Diária"
            FontFamily="CaveatBold"
            FontSize="50"
            HorizontalOptions="Center"/>

        <Frame>
            <VerticalStackLayout>
                <Grid
                    RowDefinitions="Auto,Auto"
                    ColumnDefinitions="*, *, 2*">

                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        Text="Adultos"/>

                    <Stepper 
                        Grid.Row="0"
                        Grid.Column="2"
                        x:Name="sptAdult"
                        Minimum="0"
                        Maximum="10"/>

                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        Text="{Binding Value}"
                        BindingContext="{x:Reference sptAdult}"/>

                    <Label
                         Grid.Row="1"
                         Grid.Column="0"
                         Text="Crianças"/>

                    <Label
                        Grid.Row="1"
                        Grid.Column="1"
                        Text="{Binding Value}"
                        BindingContext="{x:Reference sptKids}"/>

                    <Stepper 
                        Grid.Row="1"
                        Grid.Column="2"
                        x:Name="sptKids"
                        Minimum="0"
                        Maximum="10"/>      
                </Grid>

                <Label
                    Text="Escolha a quantidade de Suites"
                    FontFamily="CaveatBold"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    FontSize="20"
                    Padding="10"/>

                <Picker
                    x:Name="pckRoom"
                    Title="Selecione sua Acomodação"
                    FontSize="15"/>

                <Frame>
                    <VerticalStackLayout>
                        <Label 
                            Text="Período da Estadia"
                            HorizontalOptions="Center"
                            FontFamily="CaveatBold"
                            FontSize="20"/>
                        
                        <HorizontalStackLayout>
                            <Label 
                                Text="Check-in:"/>
                            <DatePicker
                                x:Name="dpStartDate"
                                Format="dd/MM/yyyy"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout>
                            <Label 
                                Text="Check-out:"/>
                            <DatePicker
                                 x:Name="dpEndDate"
                                 Format="dd/MM/yyyy"/>  
                            
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Button 
                    Text="Continuar"/>
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>